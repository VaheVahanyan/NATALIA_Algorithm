flowchart TD
    A([Вход в дежурный режим]) --> B[Ожидание команд]

    B --> C{"Событие в дежурном режиме"}

    C -- "КУ 2<br/>CMD_STATUS_REQ" --> D["Сформировать ТС 'Статус'"]
    C -- "КУ 1<br/>CMD_TELEM_REQ" --> E["Сформировать ТС 'Телеметрия'"]
    C -- "КУ 3<br/>CMD_SET_TIME" --> F[Установить приборное время]
    C -- "КУ 11<br/>CMD_TEST_RESULT" --> G["Сформировать ТС 'Результаты теста ППЗУ'"]
    C -- "КУ 6<br/>CMD_DUTY" --> H[Остаться в дежурном режиме]
    C -- "Любая КТ" --> I[Игнорировать команду]
    C -- "Запрещённая КУ" --> J[Сформировать квитанцию с ошибкой]
    C -- "КУ 8<br/>CMD_SET_CFG" --> K{"MaskedAlarm == 0"}

    K -- Да --> L[Обновить конфигурацию]
    K -- Нет --> ZA[Переход в аварийный режим]

    D --> B
    E --> B
    F --> B
    G --> B
    H --> B
    I --> B
    J --> B
    L --> B

    C -. "КУ 4<br/>CMD_OBSERVE_START" .-> M[Переход в режим наблюдений]
    C -. "КУ 9<br/>CMD_ERASE" .-> N[Переход в режим стирания ППЗУ]
    C -. "КУ 10<br/>CMD_TEST" .-> O[Переход в режим тестирования ППЗУ]
    C -. "КУ 7<br/>CMD_DUMP" .-> P[Переход в режим вывода данных]
    C -. "КУ 12<br/>CMD_SHUTDOWN" .-> Q[Переход в режим выключения]
    C -. "MaskedAlarm != 0" .-> ZA

    M --> M1["Сформировать ТС 'Статус'"]
    M1 --> M2([Выход из дежурного режима])

    N --> N1["Сформировать ТС 'Статус'"]
    N1 --> N2([Выход из дежурного режима])

    O --> O1["Сформировать ТС 'Статус'"]
    O1 --> O2([Выход из дежурного режима])

    P --> P1["Сформировать ТС 'Статус'"]
    P1 --> P2([Выход из дежурного режима])

    ZA --> ZA1["Сформировать ТС 'Статус'"]
    ZA1 --> ZA2([Выход из дежурного режима])

    Q --> Q1["Сформировать ТС 'Статус'"]
    Q1 --> Q2([Выход из дежурного режима])