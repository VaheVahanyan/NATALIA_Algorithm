flowchart TD
    A([Вход при MaskedAlarm != 0]) --> B[Зафиксировать источник аварии]
    B --> C[Остановить текущую операцию]
    C --> D[Начать переход в safe-состояние]

    D --> E[Запретить регистрацию в ПЭД]
    E --> F[Отключить питание ПЭД]
    F --> G[Отключить NAND1]
    G --> H[Отключить NAND2]
    H --> I["Safe-конфигурация достигнута<br/>ТС 'Статус' отправлен"]

    I --> J[Ожидание команд и контроля состояния]
    J --> K{"Событие в аварийном режиме"}

    K -- "КУ 2<br/>CMD_STATUS_REQ" --> L[Сформировать ТС 'Статус']
    K -- "КУ 1<br/>CMD_TELEM_REQ" --> M[Сформировать ТС 'Телеметрия']
    K -- "КУ 8<br/>CMD_SET_CFG" --> N[Обновление конфигурации]
    K -- "КУ 13<br/>CMD_RESET_ALARM" --> O[Сброс аварийного статуса]
    K -- "КУ 12<br/>CMD_SHUTDOWN" --> Y[Переход в режим выключения]
    K -- "MaskedAlarm == 0" --> Z[Переход в дежурный режим]

    L --> J
    M --> J

    N --> N1[Обновить конфигурацию]
    N1 --> N2[Записать MRAM]
    N2 --> N3[Пересчитать MaskedAlarm]
    N3 -. "MaskedAlarm != 0" .-> J
    N3 -. "MaskedAlarm == 0" .-> Z

    O --> O1[Обнулить AlarmStatus]
    O1 --> O2[Пересчитать MaskedAlarm]
    O2 -. "MaskedAlarm != 0" .-> J
    O2 -. "MaskedAlarm == 0" .-> Z

    Z --> Z1[Зафиксировать переход в дежурный режим]
    Z1 --> Z2[Не восстанавливать предыдущий режим]
    Z2 --> Z3["Сформировать ТС 'Статус'"]
    Z3 --> Z4([Выход из аварийного режима])

    Y --> Y1[Сохранить служебные данные]
    Y1 --> Y2["Сформировать ТС 'Статус'"]
    Y2 --> Y3([Выход из аварийного режима])