flowchart TD
    A([Вход по КУ 7<br/>CMD_DUMP]) --> B[Сохранить параметры КУ]
    B --> C[Выбрать банк NAND1 или NAND2]
    C --> D[Включить питание банка<br/>если требуется]
    D --> E[Определить число пакетов]
    E --> F{"Подготовка завершена<br/>MaskedAlarm == 0"}

    F -- Да --> G[Выбрать интерфейс USB или CAN]
    F -- Нет --> ZA[Завершение по аварии]

    G --> H[Проверить VBUS<br/>если выбран USB]
    H --> I{"Интерфейс готов"}

    I -- Да --> J[Считать пакет 2 кБ из NAND]
    I -- Нет --> ZA

    J --> K{"Пакет считан"}

    K -- Да --> L[Передать пакет наружу]
    K -- Нет --> ZA

    J -. "КУ 6 или КУ 12" .-> Y[Завершение по команде]
    J -. "Ошибка чтения<br/>или ошибка QSPI" .-> ZA
    J -. "MaskedAlarm != 0" .-> ZA

    L --> M{"Передача завершена"}

    M -- Да --> N[Проверка завершения]
    M -- Нет --> ZA

    L -. "КУ 6 или КУ 12" .-> Y
    L -. "Тайм-аут, ошибка передачи<br/>или нет VBUS" .-> ZA
    L -. "MaskedAlarm != 0" .-> ZA

    N --> O{"Есть ещё пакеты"}

    O -- Да --> J
    O -- Нет --> Z[Штатное завершение]

    N -. "КУ 6 или КУ 12" .-> Y
    N -. "MaskedAlarm != 0" .-> ZA

    Z --> Z1[Зафиксировать число переданных пакетов]
    Z1 --> Z2["Оставить п       итание банка<br/>или выключить по КУ"]
    Z2 --> Z3([Выход из режима вывода данных])

    Y --> Y1["Завершить или остановить передачу<br/>по принятому правилу"]
    Y1 --> Y2["Оставить питание банка<br/>или выключить по правилу выхода"]
    Y2 --> Y3([Выход из режима вывода данных])

    ZA --> ZA1[Зафиксировать аварийное завершение]
    ZA1 --> ZA2[Отключить ПЭД]
    ZA2 --> ZA3[Отключить NAND1]
    ZA3 --> ZA4[Отключить NAND2]
    ZA4 --> ZA5([Выход из режима вывода данных])