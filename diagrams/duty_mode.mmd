flowchart TD
    A([Вход в режим DUTY]) --> B[Ожидание команд и контроль состояния]

    B --> C{"Событие в режиме DUTY"}

    C -- "CMD_STATUS_REQ" --> D["Выдать ТС 'Квитанция'<br/>Выдать ТС 'Статус'"]
    C -- "CMD_TELEM_REQ" --> E["Выдать ТС 'Квитанция'<br/>Выдать ТС 'Телеметрия'"]
    C -- "CMD_SET_TIME" --> F["Выдать ТС 'Квитанция'<br/>Обновить RTC"]
    C -- "CMD_TEST_RESULT" --> G["Выдать ТС 'Квитанция'<br/>Выдать ТС 'Результаты теста ППЗУ'"]
    C -- "CMD_DUTY" --> H["Выдать ТС 'Квитанция'"]
    C -- "Любая КТ" --> I[Игнорировать команду]
    C -- "Запрещённая КУ" --> J["Выдать ТС 'Квитанция'<br/>с ошибкой"]

    C -- "CMD_SET_CFG" --> K["Выдать ТС 'Квитанция'<br/>Обновить конфигурацию<br/>Записать конфигурацию в MRAM<br/>Пересчитать MaskedAlarm"]
    K --> L{"MaskedAlarm == 0?"}
    L -- Да --> B
    L -- Нет --> ZA[Переход в ALARM]

    C -- "CMD_OBSERVE_START" --> M{"Команда корректна<br/>и банк NAND допускает запуск?"}
    M -- Да --> N["Сформировать ТС 'Статус'"]
    M -- Нет --> N0["Выдать ТС 'Квитанция'<br/>с ошибкой"]
    N --> N1([Выход из DUTY в OBSERVE])
    N0 --> B

    C -- "CMD_ERASE" --> O{"Команда корректна?"}
    O -- Да --> P["Сформировать ТС 'Статус'"]
    O -- Нет --> O0["Выдать ТС 'Квитанция'<br/>с ошибкой"]
    P --> P1([Выход из DUTY в ERASE])
    O0 --> B

    C -- "CMD_TEST" --> Q{"Команда корректна?"}
    Q -- Да --> R["Сформировать ТС 'Статус'"]
    Q -- Нет --> Q0["Выдать ТС 'Квитанция'<br/>с ошибкой"]
    R --> R1([Выход из DUTY в TEST])
    Q0 --> B

    C -- "CMD_DUMP" --> S{"Команда корректна<br/>и есть данные для вывода?"}
    S -- Да --> T["Сформировать ТС 'Статус'"]
    S -- Нет --> S0["Выдать ТС 'Квитанция'<br/>с ошибкой"]
    T --> T1([Выход из DUTY в DUMP])
    S0 --> B

    C -- "CMD_SHUTDOWN" --> U["Выдать ТС 'Квитанция'<br/>Сформировать ТС 'Статус'"]
    U --> U1([Выход из DUTY в SHUTDOWN])

    C -. "MaskedAlarm != 0" .-> ZA
    ZA --> ZA1["Привести систему<br/>к безопасной конфигурации<br/>Сформировать ТС 'Статус'"]
    ZA1 --> ZA2([Выход из DUTY в ALARM])

    D --> B
    E --> B
    F --> B
    G --> B
    H --> B
    I --> B
    J --> B