flowchart TD
    A([Вход по CMD_TEST]) --> B[Сохранить параметры команды]
    B --> C[Выбрать банк NAND1 или NAND2]
    C --> D[Включить питание выбранного банка<br/>если оно выключено]
    D --> E[Подтвердить наличие питания банка<br/>по PU_NANDx_PSON]
    E --> E1[Подключить сигнальные линии банка NAND к портам МК]
    E1 --> F[Подготовить сервис NAND к тесту]
    F --> G["Очистить массив Nerr"]
    G --> H[Подготовить буферы тестирования]
    H --> I[Сформировать ТС 'Статус']
    I --> J[Начать фазу TEST_WRITE]

    J --> K[Запись тестовой последовательности]
    K --> L{"Запись завершена?"}
    L -- Да --> M[Начать фазу TEST_READ]
    L -- Нет --> K

    K -. "Ошибка записи<br/>или ошибка интерфейса NAND" .-> ZA[Аварийное завершение]
    K -. "CMD_DUTY" .-> Y[Завершение по команде]
    K -. "CMD_SHUTDOWN" .-> X[Завершение с переходом в SHUTDOWN]
    K -. "MaskedAlarm != 0" .-> ZA

    M --> N[Чтение тестовых данных]
    N --> O{"Чтение завершено?"}
    O -- Да --> P[Начать фазу TEST_COMPARE]
    O -- Нет --> N

    N -. "Ошибка чтения<br/>или ошибка интерфейса NAND" .-> ZA
    N -. "CMD_DUTY" .-> Y
    N -. "CMD_SHUTDOWN" .-> X
    N -. "MaskedAlarm != 0" .-> ZA

    P --> Q[Сравнение записанного и считанного]
    Q --> R["Заполнение массива Nerr"]
    R --> S{"Сравнение завершено?"}
    S -- Да --> T[Начать фазу TEST_SAVE]
    S -- Нет --> Q

    Q -. "Ошибка сравнения" .-> ZA
    R -. "CMD_DUTY" .-> Y
    R -. "CMD_SHUTDOWN" .-> X
    R -. "MaskedAlarm != 0" .-> ZA

    T --> U[Записать Nerr в первую копию MRAM]
    U --> U1[Выдержать интервал завершения записи]
    U1 --> U2[Записать Nerr во вторую копию MRAM]
    U2 --> V{"Сохранение завершено?"}
    V -- Да --> W[Начать фазу TEST_ERASE]
    V -- Нет --> V1[Результат теста невалиден]
    V1 --> V2{"Получена команда завершения?"}
    V2 -- "CMD_DUTY" --> Y
    V2 -- "CMD_SHUTDOWN" --> X
    V2 -- Нет --> ZN[Нештатное завершение без ALARM]

    U -. "MaskedAlarm != 0" .-> ZA
    U1 -. "MaskedAlarm != 0" .-> ZA
    U2 -. "MaskedAlarm != 0" .-> ZA
    U -. "CMD_DUTY" .-> Y
    U -. "CMD_SHUTDOWN" .-> X
    U1 -. "CMD_DUTY" .-> Y
    U1 -. "CMD_SHUTDOWN" .-> X
    U2 -. "CMD_DUTY" .-> Y
    U2 -. "CMD_SHUTDOWN" .-> X

    W --> W1[Стереть протестированный банк NAND]
    W1 --> W2{"Стирание завершено?"}
    W2 -- Да --> Z[Штатное завершение]
    W2 -- Нет --> W1

    W1 -. "Ошибка стирания<br/>или ошибка интерфейса NAND" .-> ZA
    W1 -. "CMD_DUTY" .-> Y
    W1 -. "CMD_SHUTDOWN" .-> X
    W1 -. "MaskedAlarm != 0" .-> ZA

    Z --> Z1[Обновить результаты последнего теста]
    Z1 --> Z2["Счётчик тестов++"]
    Z2 --> Z3[Обновить служебные данные в MRAM]
    Z3 --> Z4{"Отключить питание банка?"}
    Z4 -- Да --> Z5[Отключить питание выбранного банка<br/>и отсоединить его линии от портов]
    Z4 -- Нет --> Z6[Сохранить питание выбранного банка]
    Z5 --> Z7["Сформировать ТС 'Статус'"]
    Z6 --> Z7
    Z7 --> Z8([Выход из TEST в DUTY])

    Y --> Y0["Завершить текущую фазу TEST"]
    Y0 --> Y1["Тест считается незавершённым"]
    Y1 --> Y2["Счётчик тестов не обновлять"]
    Y2 --> Y3{"Отключить питание банка?"}
    Y3 -- Да --> Y4[Отключить питание выбранного банка<br/>и отсоединить его линии от портов]
    Y3 -- Нет --> Y5[Сохранить питание выбранного банка]
    Y4 --> Y6["Сформировать ТС 'Статус'"]
    Y5 --> Y6
    Y6 --> Y7([Выход из TEST в DUTY])

    X --> X0["Завершить текущую фазу TEST"]
    X0 --> X1["Тест считается незавершённым"]
    X1 --> X2["Счётчик тестов не обновлять"]
    X2 --> X3[Передать управление режиму SHUTDOWN]
    X3 --> X4([Выход из TEST в SHUTDOWN])

    ZN --> ZN1["Счётчик тестов не обновлять"]
    ZN1 --> ZN2{"Отключить питание банка?"}
    ZN2 -- Да --> ZN3[Отключить питание выбранного банка<br/>и отсоединить его линии от портов]
    ZN2 -- Нет --> ZN4[Сохранить питание выбранного банка]
    ZN3 --> ZN5["Сформировать ТС 'Статус'"]
    ZN4 --> ZN5
    ZN5 --> ZN6([Выход из TEST в DUTY])

    ZA --> ZA1[Прекратить выполнение тестовой последовательности]
    ZA1 --> ZA2[Отключить питание ПЭД]
    ZA2 --> ZA3[Отключить питание NAND1]
    ZA3 --> ZA4[Отключить питание NAND2]
    ZA4 --> ZA4a[Отключить сигнальные линии ПЭД и NAND от портов МК]
    ZA4a --> ZA5["Сформировать ТС 'Статус'"]
    ZA5 --> ZA6([Выход из TEST в ALARM])