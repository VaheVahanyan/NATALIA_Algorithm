flowchart TD
    A([Вход по КУ 4<br/>CMD_OBSERVE_START]) --> B[Сохранить параметры запуска]
    B --> C[Выбрать активный NAND]
    C --> D[Включить питание NAND<br/>если требуется]
    D --> E[Подготовить запись НИ]
    E --> F[Включить и настроить ПЭД<br/>если требуется]
    F --> G[Применить trigger config]
    G --> H[Сбросить runtime-контекст]
    H --> I["session_id++<br/>mode_id = 0"]
    I --> J{"Подготовка завершена<br/>MaskedAlarm == 0"}

    J -- Да --> K[Активное наблюдение]
    J -- Нет --> ZA[Завершение по аварии]

    K --> L{"Событие цикла"}

    L -- RTC_1HZ --> M[Обработка тика 1 Гц]
    L -- "PED_TG<br/>регистрация разрешена" --> N[Обработка события ПЭД]
    L -- "КТ 1..4" --> O[Обработка КТ]
    L -- "КУ 5<br/>CMD_OBSERVE_CTRL" --> P[Изменение конфигурации]
    L -- "КУ 1 или КУ 2" --> Q[Выдача ТС статуса или телеметрии]

    L -. "КУ 6<br/>CMD_DUTY" .-> Y[Завершение по команде]
    L -. "КУ 12<br/>CMD_SHUTDOWN" .-> Y
    L -. "Активный NAND заполнен" .-> Z[Завершение по переполнению]
    L -. "MaskedAlarm != 0" .-> ZA

    M --> M1[Завершить секундные накопители]
    M1 --> M2["Сформировать формат 'Счетчики'"]
    M2 --> M3["Сформировать формат 'Спектр-1/2'<br/>если включен"]
    M3 --> M4["Сформировать формат 'Телеметрия'<br/>если прошло 20 с или установлен флаг"]
    M4 --> M5[Сбросить секундные буферы]
    M5 --> K

    N --> N1[Считать событие из ПЭД]
    N1 --> N2[Обновить счетчики]
    N2 --> N3[Обновить гистограмму]
    N3 --> N4["Добавить запись в формат 'События'<br/>если требуется"]
    N4 --> N5[Сформировать PED_TGRES]
    N5 --> K

    O --> O0{"Тип КТ"}
    O0 -- "КТ 1" --> O1["Сформировать формат 'Синхронизация'"]
    O0 -- "КТ 2" --> O2["Сформировать формат 'Орбита'"]
    O0 -- "КТ 3" --> O3["Сформировать формат 'Ориентация'"]
    O0 -- "КТ 4" --> O4["Сформировать формат 'Геомагнитное поле'"]
    O1 --> O5[Записать сформированный формат в NAND]
    O2 --> O5
    O3 --> O5
    O4 --> O5
    O5 --> K

    P --> P1[Обновить конфигурацию ПЭД]
    P1 --> P2[Обновить параметры наблюдения]
    P2 --> P3["mode_id++"]
    P3 --> P4["Запланировать формат 'Телеметрия'<br/>на следующем RTC_1HZ"]
    P4 --> K

    Q --> Q0{"Тип КУ"}
    Q0 -- "КУ 1" --> Q1["Сформировать ТС 'Телеметрия'"]
    Q0 -- "КУ 2" --> Q2["Сформировать ТС 'Статус'"]
    Q1 --> K
    Q2 --> K

    Y --> Y1[Запретить новые действия]
    Y1 --> Y2[Завершить текущие форматы]
    Y2 --> Y3["Дозаполнить последний пакет AAAAh<br/>если требуется"]
    Y3 --> Y4[Обновить счетчики пакетов]
    Y4 --> Y5["Сформировать итоговый формат 'Телеметрия'<br/>по правилу режима"]
    Y5 --> Y6([Выход из режима наблюдений])

    Z --> Z1[Остановить запись новых форматов]
    Z1 --> Z2[Завершить согласованную запись]
    Z2 --> Z3[Установить флаг переполнения NAND]
    Z3 --> Z4["Привести ПЭД и NAND<br/>к конфигурации после переполнения"]
    Z4 --> Z5([Выход из режима наблюдений])

    ZA --> ZA1[Запретить регистрацию в ПЭД]
    ZA1 --> ZA2[Отключить питание ПЭД]
    ZA2 --> ZA3[Отключить NAND1 и NAND2]
    ZA3 --> ZA4([Выход из режима наблюдений])