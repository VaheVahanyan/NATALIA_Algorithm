flowchart TD
    A([Подача питания]) --> B[Инициализация]
    B --> C{"Инициализация завершена<br/>и MaskedAlarm == 0?"}
    C -- Да --> D[Дежурный режим DUTY]
    C -- Нет --> E[Аварийный режим ALARM]
    D --> F{"Получена допустимая КУ?"}
    F -- Да --> G{"Тип команды"}
    G -- " CMD_OBSERVE_START " --> H[Режим наблюдений OBSERVE]
    G -- " CMD_ERASE " --> I[Режим стирания NAND ERASE]
    G -- " CMD_TEST " --> J[Режим тестирования NAND TEST]
    G -- " CMD_DUMP " --> K[Режим вывода данных DUMP]
    G -- " Иная допустимая КУ " --> D
    F -- Нет --> M{"MaskedAlarm != 0?"}
    M -- Да --> E
    M -- Нет --> D
    H -. " MaskedAlarm != 0 " .-> E
    I -. " MaskedAlarm != 0 " .-> E
    J -. " MaskedAlarm != 0 " .-> E
    K -. " MaskedAlarm != 0 " .-> E
    E -. " CMD_SHUTDOWN " .-> L
    H -. " CMD_SHUTDOWN " .-> L
    I -. " CMD_SHUTDOWN " .-> L
    J -. " CMD_SHUTDOWN " .-> L
    K -. " CMD_SHUTDOWN " .-> L
    G -- " CMD_SHUTDOWN " --> L[Режим выключения SHUTDOWN]
    H -- " CMD_DUTY / NAND_FULL " --> D
    I -- " ERASE_DONE / CMD_DUTY " --> D
    J -- " TEST_DONE / CMD_DUTY " --> D
    K -- " DUMP_DONE / CMD_DUTY " --> D
    E --> N{"MaskedAlarm == 0?"}
    N -- Да --> D
    N -- Нет --> E
    L --> O{"Питание снято?"}
    O -- Нет --> Q["Разрешена только CMD_STATUS_REQ"]
    O -- Да --> P([Конец])
    Q --> L