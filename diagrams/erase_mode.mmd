%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TD
    A([Вход по CMD_ERASE]) --> B[Сохранить параметры команды]
    B --> C[Выбрать банк NAND1 или NAND2]
    C --> D[Включить питание выбранного банка<br/>если требуется]
    D --> E[Подтвердить наличие питания банка]
    E --> F[Подготовить сервис NAND к стиранию]
    F --> G[Сформировать ТС 'Статус']
    G --> H[Запустить стирание]
    H --> I[Ожидание завершения ERASE_WAIT]

    I --> J{"Событие в режиме ERASE"}

    J -- "CMD_STATUS_REQ" --> K["Выдать ТС 'Квитанция'<br/>Выдать ТС 'Статус'"]
    J -- "ERASE_DONE" --> L[Штатное завершение]
    J -. "CMD_DUTY" .-> M[Завершение по команде]
    J -. "CMD_SHUTDOWN" .-> N[Завершение с переходом в SHUTDOWN]
    J -. "Ошибка стирания<br/>или ошибка QSPI" .-> O[Аварийное завершение]
    J -. "MaskedAlarm != 0" .-> O

    K --> I

    L --> L1[Обновить состояние банка NAND]
    L1 --> L2[Сбросить признак переполнения банка]
    L2 --> L3["Счётчик стираний++"]
    L3 --> L4[Обновить служебные данные в MRAM]
    L4 --> L5["Оставить питание банка включённым<br/>или отключить по команде"]
    L5 --> L6["Сформировать ТС 'Статус'"]
    L6 --> L7([Выход из ERASE в DUTY])

    M --> M1["Завершить режим по принятому правилу<br/>досрочного завершения"]
    M1 --> M2["Оставить питание банка включённым<br/>или отключить по правилу выхода"]
    M2 --> M3["Сформировать ТС 'Статус'"]
    M3 --> M4([Выход из ERASE в DUTY])

    N --> N1["Завершить режим по принятому правилу<br/>выхода в SHUTDOWN"]
    N1 --> N2["Оставить питание банка включённым<br/>или отключить по правилу выхода"]
    N2 --> N3["Сформировать ТС 'Статус'"]
    N3 --> N4([Выход из ERASE в SHUTDOWN])

    O --> O1[Прекратить нормальную последовательность стирания]
    O1 --> O2[Отключить питание ПЭД]
    O2 --> O3[Отключить питание NAND1]
    O3 --> O4[Отключить питание NAND2]
    O4 --> O5["Сформировать ТС 'Статус'"]
    O5 --> O6([Выход из ERASE в ALARM])