flowchart TD
    A([Вход по CMD_ERASE]) --> B[Сохранить параметры команды]
    B --> C[Выбрать банк NAND1 или NAND2]
    C --> D[Включить питание выбранного банка<br/>если оно выключено]
    D --> E[Подтвердить наличие питания банка<br/>по PU_NANDx_PSON]
    E --> E1[Подключить сигнальные линии банка NAND к портам МК]
    E1 --> F[Подготовить сервис NAND к стиранию]
    F --> G[Сформировать ТС 'Статус']
    G --> H[Запустить стирание]
    H --> I[Ожидание завершения ERASE_WAIT]

    I --> J{"Событие в режиме ERASE"}

    J -- "CMD_STATUS_REQ" --> K["Выдать ТС 'Квитанция'<br/>Выдать ТС 'Статус'"]
    J -- "ERASE_DONE" --> L[Штатное завершение]
    J -. "CMD_DUTY" .-> M[Завершение по команде]
    J -. "CMD_SHUTDOWN" .-> N[Завершение с переходом в SHUTDOWN]
    J -. "Ошибка стирания<br/>или ошибка интерфейса NAND" .-> O[Аварийное завершение]
    J -. "Потеря подтверждения питания банка" .-> O
    J -. "MaskedAlarm != 0" .-> O

    K --> I

    L --> L1[Обновить состояние банка NAND]
    L1 --> L2[Сбросить признак переполнения банка]
    L2 --> L3["Счётчик стираний++"]
    L3 --> L4[Обновить служебные данные в MRAM]
    L4 --> L5{"Отключить питание банка?"}
    L5 -- Да --> L6[Отключить питание выбранного банка<br/>и отсоединить его линии от портов]
    L5 -- Нет --> L7[Сохранить питание выбранного банка]
    L6 --> L8["Сформировать ТС 'Статус'"]
    L7 --> L8
    L8 --> L9([Выход из ERASE в DUTY])

    M --> M0["Дождаться завершения текущего цикла стирания<br/>если безопасное прерывание не гарантировано"]
    M0 --> M1["Стирание считается незавершённым"]
    M1 --> M2["Счётчик стираний не обновлять"]
    M2 --> M3{"Отключить питание банка?"}
    M3 -- Да --> M4[Отключить питание выбранного банка<br/>и отсоединить его линии от портов]
    M3 -- Нет --> M5[Сохранить питание выбранного банка]
    M4 --> M6["Сформировать ТС 'Статус'"]
    M5 --> M6
    M6 --> M7([Выход из ERASE в DUTY])

    N --> N0["Дождаться завершения текущего цикла стирания<br/>если безопасное прерывание не гарантировано"]
    N0 --> N1["Стирание считается незавершённым"]
    N1 --> N2["Счётчик стираний не обновлять"]
    N2 --> N3[Передать управление режиму SHUTDOWN]
    N3 --> N4([Выход из ERASE в SHUTDOWN])

    O --> O1[Прекратить нормальную последовательность стирания]
    O1 --> O2[Отключить питание ПЭД]
    O2 --> O3[Отключить питание NAND1]
    O3 --> O4[Отключить питание NAND2]
    O4 --> O4a[Отключить сигнальные линии NAND от портов МК]
    O4a --> O5["Сформировать ТС 'Статус'"]
    O5 --> O6([Выход из ERASE в ALARM])