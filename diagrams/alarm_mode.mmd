flowchart TD
    A([Вход при MaskedAlarm != 0]) --> B[Зафиксировать источник перехода]
    B --> C[Зафиксировать аварийный статус]
    C --> D[Остановить или прекратить текущую операцию]
    D --> E[Запретить регистрацию событий в ПЭД]
    E --> F[Отключить питание ПЭД]
    F --> G[Отключить питание NAND1]
    G --> H[Отключить питание NAND2]
    H --> H1[Отключить сигнальные линии ПЭД и NAND от портов МК]
    H1 --> I[Проверить достижение безопасной конфигурации]
    I --> J["Сформировать ТС 'Статус'"]
    J --> K[Ожидание команд и контроля состояния]

    K --> L{"Событие в режиме ALARM"}

    L -- "CMD_STATUS_REQ" --> M["Выдать ТС 'Квитанция'<br/>Выдать ТС 'Статус'"]
    L -- "CMD_TELEM_REQ" --> N["Выдать ТС 'Квитанция'<br/>Выдать ТС 'Телеметрия'"]
    L -- "CMD_SET_CFG" --> O[Обновление конфигурации]
    L -- "CMD_RESET_ALARM" --> P[Сброс аварийного статуса]
    L -- "CMD_SHUTDOWN" --> Y[Переход в SHUTDOWN]
    L -- "Повторное появление аварии" --> K

    M --> K
    N --> K

    O --> O1[Обновить конфигурацию]
    O1 --> O2[Обновить маску аварий]
    O2 --> O3[Записать конфигурацию в первую копию MRAM]
    O3 --> O4[Выдержать интервал завершения записи]
    O4 --> O5[Записать конфигурацию во вторую копию MRAM]
    O5 --> O6[Сделать конфигурацию рабочей]
    O6 --> O7[Пересчитать MaskedAlarm]
    O7 --> O8{"MaskedAlarm == 0?"}
    O8 -- Да --> Z[Выход в DUTY]
    O8 -- Нет --> K

    P --> P1[Обнулить AlarmStatus]
    P1 --> P2[Пересчитать MaskedAlarm]
    P2 --> P3{"MaskedAlarm == 0?"}
    P3 -- Да --> Z
    P3 -- Нет --> K

    Z --> Z1[Зафиксировать завершение аварийного режима]
    Z1 --> Z2[Не восстанавливать предыдущий целевой режим]
    Z2 --> Z3[Оставить систему в безопасной дежурной конфигурации]
    Z3 --> Z4["Сформировать ТС 'Статус'"]
    Z4 --> Z5([Выход из ALARM в DUTY])

    Y --> Y1[Проверить безопасную конфигурацию]
    Y1 --> Y2[Сохранить минимально необходимые служебные данные]
    Y2 --> Y3["Сформировать ТС 'Статус'"]
    Y3 --> Y4([Выход из ALARM в SHUTDOWN])