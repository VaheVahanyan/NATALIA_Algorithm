flowchart TD
    A([Вход по КУ 12<br/>CMD_SHUTDOWN]) --> B[Зафиксировать исходный режим]
    B --> C[Начать завершение или остановку]
    C --> D["Завершить текущую операцию<br/>по правилу исходного режима"]
    D --> E[Сохранение служебных данных]
    E --> F["Сохранить служебные данные в MRAM"]
    F --> G[Отключение аппаратуры]
    G --> H[Отключить питание ПЭД]
    H --> I["Отключить активный NAND<br/>или оба NAND"]
    I --> J["Сформировать и отправить ТС 'Статус'"]
    J --> K[Ожидание снятия питания]

    K --> L{"Событие в режиме выключения"}

    L -- "КУ 2<br/>CMD_STATUS_REQ" --> M[Сформировать ТС 'Статус']
    L -- "Снятие питания" --> N([Выход из режима выключения])

    M --> K