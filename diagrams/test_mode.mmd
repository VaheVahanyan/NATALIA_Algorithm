flowchart TD
    A([Вход по КУ 10<br/>CMD_TEST]) --> B[Сохранить параметры КУ]
    B --> C[Выбрать банк NAND1 или NAND2]
    C --> D[Включить питание банка<br/>если требуется]
    D --> E[Дождаться PSON<br/>если требуется]
    E --> F["Очистить массив Nerr[2048]"]
    F --> G{"Подготовка завершена<br/>MaskedAlarm == 0"}

    G -- Да --> H[Запись тестовых данных]
    G -- Нет --> ZA[Завершение по аварии]

    H --> H1[Записывать тестовый шаблон]
    H1 --> I[Чтение тестовых данных]

    H1 -. "Ошибка записи<br/>или ошибка QSPI" .-> ZA
    H1 -. "КУ 6 или КУ 12" .-> Y[Завершение по команде]
    H1 -. "MaskedAlarm != 0" .-> ZA

    I --> I1[Читать тестовые данные]
    I1 --> J[Сравнение и подсчёт ошибок]

    I1 -. "Ошибка чтения<br/>или ошибка QSPI" .-> ZA
    I1 -. "КУ 6 или КУ 12" .-> Y
    I1 -. "MaskedAlarm != 0" .-> ZA

    J --> J1[Сравнивать записанное и считанное]
    J1 --> J2["Заполнять Nerr[block]"]
    J2 --> K[Сохранение результатов]

    J2 -. "Ошибка сравнения" .-> ZA
    J2 -. "КУ 6 или КУ 12" .-> Y
    J2 -. "MaskedAlarm != 0" .-> ZA

    K --> K1[Записать Nerr в MRAM]
    K1 --> Z[Штатное завершение]

    K1 -. "Ошибка MRAM" .-> ZA
    K1 -. "КУ 6 или КУ 12" .-> Y
    K1 -. "MaskedAlarm != 0" .-> ZA

    Z --> Z1[Обновить результаты теста]
    Z1 --> Z2["Счетчик тестов++"]
    Z2 --> Z3["Обновить MRAM<br/>если требуется"]
    Z3 --> Z4["Оставить питание банка<br/>или выключить по КУ"]
    Z4 --> Z5([Выход из режима тестирования])

    Y --> Y1["Завершить или остановить тест<br/>по принятому правилу"]
    Y1 --> Y2["Оставить питание банка<br/>или выключить по правилу выхода"]
    Y2 --> Y3([Выход из режима тестирования])

    ZA --> ZA1[Зафиксировать аварийное завершение]
    ZA1 --> ZA2[Отключить ПЭД]
    ZA2 --> ZA3[Отключить NAND1]
    ZA3 --> ZA4[Отключить NAND2]
    ZA4 --> ZA5([Выход из режима тестирования])