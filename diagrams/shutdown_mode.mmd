flowchart TD
    A([Вход по CMD_SHUTDOWN]) --> B[Зафиксировать исходный режим]
    B --> C[Начать завершение или останов текущей активности]
    C --> D["Завершить или остановить текущий режим<br/>по правилу исходного режима"]
    D --> E[Сохранить служебные данные в MRAM]
    E --> F[Отключить питание ПЭД]
    F --> G["Отключить активный банк NAND<br/>или оба банка NAND"]
    G --> H[Проверить достижение безопасной конфигурации]
    H --> I["Сформировать ТС 'Статус'"]
    I --> J[Ожидание снятия питания]

    J --> K{"Событие в режиме SHUTDOWN"}

    K -- "CMD_STATUS_REQ" --> L["Выдать ТС 'Квитанция'<br/>Выдать ТС 'Статус'"]
    K -- "Питание снято" --> M([Конец])

    L --> J